DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here
DISCORD_GUILD_ID=your_guild_id_here
DATABASE_URL=postgres://livid:livid@localhost:15432/livid?sslmode=disable
APP_ENV=development
LOG_FORMAT=json
LOG_LEVEL=info
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs/bot.log
LOG_FILE_MAX_SIZE_MB=10
LOG_FILE_MAX_BACKUPS=900
LOG_FILE_MAX_AGE_DAYS=730
LOG_FILE_COMPRESS=true
OTEL_SERVICE_NAME=livid-bot
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_RESOURCE_ATTRIBUTES=service.namespace=livid-bot,deployment.environment=development
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
